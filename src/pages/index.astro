---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase.js';

const { data: products, error } = await supabase
  .from('perfumes') // Mapping into the existing backend structure safely
  .select('*')
  .order('id');

if (error) console.error('Error fetching inventory catalog:', error.message);

// Safely generate categories list. Support both 'Fragrances', 'Accessories' and legacy classifications
const rawCategories = Array.from(new Set((products || []).map(p => {
    const cat = (p.category || 'Classic').trim();
    return cat.charAt(0).toUpperCase() + cat.slice(1).toLowerCase();
})));

const categoryList = rawCategories.map(c => `'${c}'`).join(', ');
const sectionXData = `{ filter: 'All', categories: [${categoryList}] }`;

// Filter products to showcase in the "Curated Highlights" sliding gallery
const sliderProducts = (products || []).slice(0, 6); // Curates top 6 items automatically

// Robust helper function to catch any variation of 'N/A', 'n/a', or empty spaces
const isSafe = (val) => {
    if (!val) return false;
    const cleaned = String(val).trim().toUpperCase();
    return cleaned !== 'N/A' && cleaned !== 'NA' && cleaned !== '';
};

// Strict escaper to prevent database strings from breaking the Alpine JS syntax
const escapeAttr = (str) => {
    if (!str) return '';
    return String(str).replace(/'/g, "\\'").replace(/"/g, "&quot;");
};
---

<Layout title="Aju | Crafted Fragrances & Premium Accessories">
    
    <!-- Self-Healing Local Storage Script for returning Laptop browsers -->
    <script is:inline>
        (function() {
            try {
                const stored = localStorage.getItem('cartItems');
                if (stored) {
                    const parsed = JSON.parse(stored);
                    if (Array.isArray(parsed)) {
                        const needsUpgrade = parsed.some(item => !item.hasOwnProperty('image_url') || item.price === undefined || item.volume === 'N/A');
                        if (needsUpgrade) {
                            console.log('Stale testing metadata detected. Self-healing client local storage...');
                            localStorage.removeItem('cartItems');
                        }
                    }
                }
            } catch (e) {
                localStorage.removeItem('cartItems');
            }
        })();
    </script>

    <!-- Unified Lifestyle Hero Section -->
    <section class="relative h-[90vh] flex items-center justify-center overflow-hidden bg-[#0a0a0a]">
        <!-- Gradient Mesh Background for Luxury Vibe -->
        <div class="absolute inset-0">
            <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] rounded-full bg-gray-800 blur-[120px] opacity-30"></div>
            <div class="absolute bottom-[-20%] right-[-10%] w-[50%] h-[50%] rounded-full bg-neutral-800 blur-[120px] opacity-20"></div>
        </div>
        
        <div class="relative z-10 text-center px-6 max-w-5xl mx-auto flex flex-col items-center">
            <span class="text-white/60 uppercase tracking-[0.4em] text-[10px] font-bold mb-8 border border-white/20 px-6 py-2 rounded-full backdrop-blur-sm">Aju House Curation</span>
            
            <h1 class="text-5xl sm:text-7xl lg:text-[6rem] text-white font-serif mb-8 leading-[1.1] font-medium tracking-tight">
                Crafted Scent. <br>
                <span class="italic font-light text-gray-300">Refined Objects.</span>
            </h1>
            
            <p class="text-base sm:text-lg text-gray-400 mb-12 font-light max-w-xl leading-relaxed mx-auto">
                Immerse yourself in our signature hand-bottled perfumes and highly durable, minimal mobile accessories. Built for the modern aesthetic.
            </p>
            
            <a href="#shop" class="bg-white text-black px-12 py-5 uppercase text-[11px] font-bold tracking-[0.25em] hover:bg-gray-200 transition-all duration-500 rounded-sm shadow-[0_0_40px_rgba(255,255,255,0.15)] hover:shadow-[0_0_60px_rgba(255,255,255,0.25)]">
                Explore Curation
            </a>
        </div>
    </section>

    <!-- LUXURY MANUAL-SCROLL CURATED SLIDER SECTION -->
    <section class="py-24 sm:py-32 bg-[#fafafa] border-b border-gray-100 overflow-hidden" 
             x-data="{
                scrollLeft() {
                    this.$refs.sliderContainer.scrollBy({ left: -320, behavior: 'smooth' });
                },
                scrollRight() {
                    const el = this.$refs.sliderContainer;
                    if (!el) return;
                    // Reset to beginning if at the end of scroll
                    if (el.scrollLeft + el.clientWidth >= el.scrollWidth - 30) {
                        el.scrollTo({ left: 0, behavior: 'smooth' });
                    } else {
                        el.scrollBy({ left: 320, behavior: 'smooth' });
                    }
                }
             }">
        <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
            
            <div class="flex justify-between items-end mb-12 sm:mb-16">
                <div>
                    <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest block mb-2">Signature Gallery</span>
                    <h2 class="text-3xl sm:text-4xl font-serif font-medium tracking-tight text-gray-900">Curated Masterpieces</h2>
                </div>
                
                <!-- Minimalist Navigation Controls -->
                <div class="flex gap-4">
                    <button @click="scrollLeft()" class="w-12 h-12 rounded-full border border-gray-200 bg-white flex items-center justify-center text-gray-600 hover:text-black hover:border-black active:scale-95 transition-all shadow-sm focus:outline-none">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path></svg>
                    </button>
                    <button @click="scrollRight()" class="w-12 h-12 rounded-full border border-gray-200 bg-white flex items-center justify-center text-gray-600 hover:text-black hover:border-black active:scale-95 transition-all shadow-sm focus:outline-none">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                </div>
            </div>

            <!-- Dynamic Horizontal Sliding Container -->
            <div x-ref="sliderContainer" class="flex gap-6 sm:gap-8 overflow-x-auto no-scrollbar snap-x snap-mandatory scroll-smooth pb-8">
                {sliderProducts.map((product) => {
                    const rawCategory = product.category || 'Classic';
                    const categoryNormalized = rawCategory.toString().trim().charAt(0).toUpperCase() + rawCategory.toString().trim().slice(1).toLowerCase();
                    const isAccessory = categoryNormalized.includes('Accessory') || categoryNormalized.includes('Accessories');
                    
                    const imageUrl = product.image_url ? String(product.image_url).split(',')[0].trim() : '';
                    const productName = product.name || 'Premium Item';
                    const productPrice = Number(product.price || 0);

                    // Option / Variant Parsing
                    const rawVolumeStr = product.volume || '';
                    let parsedVariants = [];
                    let hasVariants = false;
                    
                    if (rawVolumeStr.includes(',')) {
                        hasVariants = true;
                        parsedVariants = rawVolumeStr.split(',').map(v => {
                            const trimV = v.trim();
                            if (trimV.includes(':')) {
                                const parts = trimV.split(':');
                                const parsedPrice = parseFloat(parts[1].replace(/[^\d.]/g, ''));
                                return {
                                    label: parts[0].trim(),
                                    price: !isNaN(parsedPrice) ? parsedPrice : productPrice
                                };
                            } else {
                                return {
                                    label: trimV,
                                    price: productPrice
                                };
                            }
                        });
                    }

                    const defaultPrice = parsedVariants.length > 0 ? parsedVariants[0].price : productPrice;
                    const variantsJson = JSON.stringify(parsedVariants).replace(/'/g, "\\'");
                    const safeName = escapeAttr(productName);
                    const safeImageUrl = escapeAttr(imageUrl);
                    const safeVolume = isSafe(product.volume) ? escapeAttr(product.volume) : '';

                    const stock = Number(product.stock_quantity || 0);
                    const isOutOfStock = stock <= 0;
                    const isLowStock = stock > 0 && stock <= 5;

                    return (
                        <div class="snap-start w-[280px] sm:w-[320px] shrink-0 bg-white border border-gray-100 rounded-lg p-3 hover:shadow-xl hover:shadow-gray-200/50 transition-all duration-300"
                             x-data={`{
                                variants: ${variantsJson},
                                selectedVariant: '${parsedVariants.length > 0 ? parsedVariants[0].label.replace(/'/g, "\\'") : ""}',
                                currentPrice: ${defaultPrice}
                             }`}>
                            
                            {/* Slide Image */}
                            <div class="aspect-[3/4] w-full bg-[#fcfcfc] rounded-md relative mb-6 overflow-hidden flex items-center justify-center">
                                {isOutOfStock && (
                                    <span class="absolute top-3 right-3 bg-red-600 text-white px-2.5 py-1 text-[8px] font-bold uppercase tracking-widest z-20 shadow-sm rounded-sm">Out of Stock</span>
                                )}
                                {isLowStock && (
                                    <span class="absolute top-3 right-3 bg-amber-100 text-amber-800 px-2.5 py-1 text-[8px] font-bold uppercase tracking-widest z-20 shadow-sm border border-amber-200 rounded-sm">Few Stock Left</span>
                                )}

                                {imageUrl ? (
                                    <img src={imageUrl} alt={productName} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" />
                                ) : (
                                    <span class="text-gray-300 font-serif italic text-xl px-4 text-center">{productName.split(' ')[0]}</span>
                                )}
                            </div>

                            {/* Details & Selectors */}
                            <div class="text-center">
                                <h3 class="font-serif text-base sm:text-lg font-medium text-gray-900 truncate mb-1">{productName}</h3>
                                
                                {hasVariants ? (
                                    <div class="my-2 max-w-[200px] mx-auto">
                                        <select 
                                            x-model="selectedVariant"
                                            @change="const found = variants.find(v => v.label === selectedVariant); if (found) { currentPrice = found.price; }"
                                            class="w-full bg-gray-50 border border-gray-200 text-[9px] font-bold uppercase tracking-wider py-1.5 px-2 focus:outline-none rounded-sm"
                                        >
                                            {parsedVariants.map(v => (
                                                <option value={v.label}>{v.label} (₹{v.price.toLocaleString('en-IN')})</option>
                                            ))}
                                        </select>
                                    </div>
                                ) : (
                                    <div class="text-[8px] sm:text-[9px] text-gray-500 uppercase tracking-widest mb-3 font-bold">
                                        <span>{isAccessory ? 'Accessory' : categoryNormalized}</span>
                                        {isSafe(product.volume) && ` • ${product.volume}`}
                                    </div>
                                )}

                                <button 
                                    @click.stop={`$store.cart.add({ id: ${product.id || 0}, name: '${safeName}', price: currentPrice, volume: selectedVariant || '${safeVolume}', image_url: '${safeImageUrl}' })`}
                                    disabled={isOutOfStock}
                                    class={`w-full py-3 mt-3 uppercase text-[9px] sm:text-[10px] font-bold tracking-[0.2em] rounded-sm transition-colors ${isOutOfStock ? 'bg-gray-100 text-gray-400 cursor-not-allowed border border-gray-200' : 'bg-black text-white hover:bg-neutral-800'}`}
                                >
                                    {isOutOfStock ? 'Sold Out' : (
                                        <span x-text="'Add — ₹' + Number(currentPrice).toLocaleString('en-IN')">
                                            Add — ₹{defaultPrice.toLocaleString('en-IN')}
                                        </span>
                                    )}
                                </button>
                            </div>
                        </div>
                    );
                })}
            </div>
            
            <p class="text-center text-[10px] text-gray-400 uppercase tracking-widest font-semibold mt-4">Swipe or drag left / right to browse the catalog</p>
        </div>
    </section>

    <!-- Refined Product Grid Section -->
    <section id="shop" class="py-24 sm:py-32 px-4 sm:px-6 lg:px-12 max-w-[1400px] mx-auto" 
             x-data={sectionXData} 
             x-init="
                const updateFilter = () => {
                    const hash = window.location.hash.substring(1).toLowerCase();
                    if (hash === 'fragrances') {
                        filter = 'Classic'; // Auto-routes legacy categories or 'Classic/Premium' perfumes
                    } else if (hash === 'accessories') {
                        filter = 'Accessories';
                    } else {
                        filter = 'All'; 
                    }
                };
                updateFilter();
                window.addEventListener('hashchange', updateFilter);
             ">
        
        <div class="flex flex-col md:flex-row justify-between items-center md:items-end mb-12 sm:mb-20 border-b border-gray-200 pb-8 gap-6 sm:gap-8">
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-serif font-medium tracking-tight text-gray-900 text-center md:text-left">The Full Collection</h2>
            
            <!-- Dynamic Category Navigation Tabs -->
            <div class="flex flex-wrap gap-4 justify-center sm:gap-12">
                <button @click="filter = 'All'; window.location.hash = 'shop'" 
                        :class="filter === 'All' ? 'text-black border-b border-black' : 'text-gray-400 border-transparent hover:text-black'" 
                        class="pb-1 uppercase text-[10px] sm:text-[11px] font-bold tracking-[0.2em] transition-colors">
                    All Objects
                </button>
                
                <button @click="filter = 'Fragrances'; window.location.hash = 'fragrances'" 
                        :class="filter === 'Fragrances' || filter === 'Classic' || filter === 'Premium' ? 'text-black border-b border-black' : 'text-gray-400 border-transparent hover:text-black'" 
                        class="pb-1 uppercase text-[10px] sm:text-[11px] font-bold tracking-[0.2em] transition-colors">
                    Fragrances
                </button>

                <button @click="filter = 'Accessories'; window.location.hash = 'accessories'" 
                        :class="filter === 'Accessories' ? 'text-black border-b border-black' : 'text-gray-400 border-transparent hover:text-black'" 
                        class="pb-1 uppercase text-[10px] sm:text-[11px] font-bold tracking-[0.2em] transition-colors">
                    Accessories
                </button>
            </div>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-4 sm:gap-x-12 gap-y-12 sm:gap-y-24">
            
            {(products || []).map((product) => {
                const rawCategory = product.category || 'Classic';
                const categoryNormalized = rawCategory.toString().trim().charAt(0).toUpperCase() + rawCategory.toString().trim().slice(1).toLowerCase();
                
                // Determine layout alignment based on category grouping
                const isAccessory = categoryNormalized.includes('Accessory') || categoryNormalized.includes('Accessories');
                
                const imageUrl = product.image_url ? String(product.image_url).split(',')[0].trim() : '';
                const productName = product.name || 'Premium Item';
                const productPrice = Number(product.price || 0);
                
                // Parse options / variants on Server-Side to inject into local Alpine state securely
                const rawVolumeStr = product.volume || '';
                let parsedVariants = [];
                let hasVariants = false;
                
                if (rawVolumeStr.includes(',')) {
                    hasVariants = true;
                    parsedVariants = rawVolumeStr.split(',').map(v => {
                        const trimV = v.trim();
                        if (trimV.includes(':')) {
                            const parts = trimV.split(':');
                            const parsedPrice = parseFloat(parts[1].replace(/[^\d.]/g, ''));
                            return {
                                label: parts[0].trim(),
                                price: !isNaN(parsedPrice) ? parsedPrice : productPrice
                            };
                        } else {
                            return {
                                label: trimV,
                                price: productPrice
                            };
                        }
                    });
                }
                
                const defaultPrice = parsedVariants.length > 0 ? parsedVariants[0].price : productPrice;
                const variantsJson = JSON.stringify(parsedVariants).replace(/'/g, "\\'");
                
                // Safe Alpine bindings
                let xShow = '';
                if (isAccessory) {
                    xShow = `filter === 'All' || filter === 'Accessories'`;
                } else {
                    xShow = `filter === 'All' || filter === 'Fragrances' || filter === '${categoryNormalized}'`;
                }

                const safeName = escapeAttr(productName);
                const safeImageUrl = escapeAttr(imageUrl);
                const safeVolume = isSafe(product.volume) ? escapeAttr(product.volume) : '';
                
                // Inventory Logic
                const stock = Number(product.stock_quantity || 0);
                const isOutOfStock = stock <= 0;
                const isLowStock = stock > 0 && stock <= 5;
                
                return (
                    <div 
                        class="group flex flex-col cursor-pointer animate-none bg-white p-2 rounded-sm border border-transparent hover:border-gray-100 transition-all duration-300"
                        x-show={xShow}
                        x-data={`{
                            variants: ${variantsJson},
                            selectedVariant: '${parsedVariants.length > 0 ? parsedVariants[0].label.replace(/'/g, "\\'") : ""}',
                            currentPrice: ${defaultPrice}
                        }`}
                        x-transition:enter="transition-opacity duration-500 ease-out"
                        x-transition:enter-start="opacity-0 translate-y-4"
                        x-transition:enter-end="opacity-100 translate-y-0"
                    >
                        {/* Static Image Container */}
                        <div class="aspect-[3/4] w-full bg-[#f4f4f4] relative mb-4 sm:mb-8 overflow-hidden flex items-center justify-center transition-colors duration-500 group-hover:bg-[#ebebeb]">
                            
                            {/* DYNAMIC STOCK BADGES */}
                            {isOutOfStock && (
                                <span class="absolute top-4 right-4 bg-red-600 text-white px-3 py-1 text-[8px] font-bold uppercase tracking-widest z-20 shadow-sm">Out of Stock</span>
                            )}
                            {isLowStock && (
                                <span class="absolute top-4 right-4 bg-amber-100 text-amber-800 px-3 py-1 text-[8px] font-bold uppercase tracking-widest z-20 shadow-sm border border-amber-200">Few Stock Left</span>
                            )}

                            {imageUrl ? (
                                <>
                                    <img 
                                        src={imageUrl} 
                                        alt={productName} 
                                        class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 ${isOutOfStock ? 'opacity-60 grayscale' : ''}`}
                                        onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
                                    />
                                    <span class="hidden text-gray-400 font-serif italic text-xl sm:text-3xl px-4 text-center transition-transform duration-700 group-hover:scale-105">
                                        {productName.split(' ')[0]}
                                    </span>
                                </>
                            ) : (
                                <span class="text-gray-400 font-serif italic text-xl sm:text-3xl px-4 text-center transition-transform duration-700 group-hover:scale-105">
                                    {productName.split(' ')[0]}
                                </span>
                            )}
                            
                            {/* Slide-up Add to Cart (Desktop with reactive price state) */}
                            <div class="hidden lg:block absolute inset-x-0 bottom-0 p-6 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] z-30">
                                <button 
                                    @click.stop={`$store.cart.add({ id: ${product.id || 0}, name: '${safeName}', price: currentPrice, volume: selectedVariant || '${safeVolume}', image_url: '${safeImageUrl}' })`}
                                    disabled={isOutOfStock}
                                    class={`w-full py-4 uppercase text-[10px] font-bold tracking-[0.2em] transition-colors duration-300 shadow-xl ${isOutOfStock ? 'bg-gray-200 text-gray-400 cursor-not-allowed' : 'bg-white text-black hover:bg-black hover:text-white'}`}
                                >
                                    {isOutOfStock ? 'Sold Out' : (
                                        <span x-text="'Add to Bag — ₹' + Number(currentPrice).toLocaleString('en-IN')">
                                            Add to Bag — ₹{defaultPrice.toLocaleString('en-IN')}
                                        </span>
                                    )}
                                </button>
                            </div>
                        </div>

                        {/* Minimalist Typography */}
                        <div class="text-center px-1 sm:px-2 flex-grow flex flex-col justify-between">
                            <div>
                                <h3 class="font-serif text-base sm:text-xl font-medium text-gray-900 mb-1 sm:mb-2 leading-tight">
                                    {productName}
                                </h3>
                                
                                {/* RECTIVE DROPDOWN / STATIC OPTION MATRIX */}
                                {hasVariants ? (
                                    <div class="mt-2 mb-3 max-w-[220px] mx-auto relative z-20" @click.stop="">
                                        <select 
                                            x-model="selectedVariant"
                                            @change="const found = variants.find(v => v.label === selectedVariant); if (found) { currentPrice = found.price; }"
                                            class="w-full bg-white border border-gray-200 text-[10px] font-bold uppercase tracking-wider py-2 px-3 focus:outline-none focus:border-black rounded-sm appearance-none text-center cursor-pointer"
                                            style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23666666%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%0-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 0.75rem center; background-size: 0.5rem auto; padding-right: 2rem;"
                                        >
                                            {parsedVariants.map(v => (
                                                <option value={v.label}>{v.label} (₹{v.price.toLocaleString('en-IN')})</option>
                                            ))}
                                        </select>
                                    </div>
                                ) : (
                                    <div class="flex items-center justify-center gap-1 sm:gap-2 text-[8px] sm:text-[9px] text-gray-500 uppercase tracking-[0.2em] mb-2 sm:mb-4 font-bold">
                                        <span>{isAccessory ? 'Accessory' : categoryNormalized}</span>
                                        {isSafe(product.volume) && (
                                            <>
                                                <span>•</span>
                                                <span>{product.volume}</span>
                                            </>
                                        )}
                                    </div>
                                )}
                                
                                <!-- DESCRIPTIVE TEXT NOTES -->
                                {isSafe(product.notes) && (
                                    <p class="text-xs sm:text-sm text-gray-500 font-light leading-relaxed line-clamp-2 mb-4 sm:mb-6 max-w-[280px] mx-auto hidden sm:block">
                                        {product.notes}
                                    </p>
                                )}
                            </div>
                            
                            {/* Mobile fallback button (WITH EXPLICIT PRICE NOW DYNAMICALLY STATE-BOUND) */}
                            <button 
                                @click.stop={`$store.cart.add({ id: ${product.id || 0}, name: '${safeName}', price: currentPrice, volume: selectedVariant || '${safeVolume}', image_url: '${safeImageUrl}' })`}
                                disabled={isOutOfStock}
                                class={`lg:hidden w-full border py-2.5 sm:py-3 uppercase text-[9px] sm:text-[10px] font-bold tracking-[0.2em] transition-colors mt-2 ${isOutOfStock ? 'border-gray-100 bg-gray-50 text-gray-400 cursor-not-allowed' : 'border-gray-200 text-gray-900 hover:bg-gray-50'}`}
                            >
                                {isOutOfStock ? 'Sold Out' : (
                                    <span x-text="'Add to Bag — ₹' + Number(currentPrice).toLocaleString('en-IN')">
                                        Add to Bag — ₹{defaultPrice.toLocaleString('en-IN')}
                                    </span>
                                )}
                            </button>
                        </div>
                    </div>
                );
            })}
            
            {/* Empty State for Filters */}
            <div x-show="!categories.some(cat => filter === 'All' || (filter === 'Fragrances' && (cat === 'Classic' || cat === 'Premium')) || cat === filter)" style="display: none;" class="col-span-full py-12 text-center text-gray-400 font-serif italic text-lg">
                No products found in this collection.
            </div>

        </div>
    </section>

</Layout>