---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Account | Aju Perfumes">
    <script type="module">
        import { supabase } from '../lib/supabase.js';
        window.supabase = supabase;
    </script>

    <div class="min-h-[90vh] flex items-center justify-center px-4 sm:px-6 lg:px-8 bg-[#fafafa] pt-20 pb-12">
        
        <div class="w-full max-w-md bg-white p-8 sm:p-12 border border-gray-100 shadow-2xl shadow-gray-200/50"
             x-data="{
                isLogin: true,
                email: '',
                password: '',
                isLoading: false,
                message: '',
                isError: false,
                
                async handleAuth() {
                    this.isLoading = true;
                    this.message = '';
                    
                    try {
                        if (this.isLogin) {
                            // LOG IN LOGIC
                            const { data, error } = await window.supabase.auth.signInWithPassword({
                                email: this.email,
                                password: this.password,
                            });
                            if (error) {
                                // Friendly hint if they get invalid credentials
                                if (error.message.toLowerCase().includes('invalid login credentials')) {
                                    throw new Error('Invalid login credentials. If you do not have an account yet, click Create Account below.');
                                }
                                throw error;
                            }
                            
                            // Success - Redirect back to the Homepage
                            window.location.href = '/';
                        } else {
                            // SIGN UP LOGIC
                            const { data, error } = await window.supabase.auth.signUp({
                                email: this.email,
                                password: this.password,
                            });
                            if (error) throw error;
                            
                            // If Supabase returns an empty identities array, the email already existed in the database!
                            const alreadyExists = data.user && data.user.identities && data.user.identities.length === 0;
                            
                            if (alreadyExists) {
                                this.message = 'An account with this email already exists. Please sign in using your existing password.';
                                this.isError = true;
                            } else {
                                this.message = 'Account created successfully! Please check your email inbox for a verification link to activate your account before logging in.';
                                this.isError = false;
                                this.isLogin = true; // Switch to login view so they can sign in after verifying
                                this.password = '';
                            }
                        }
                    } catch (err) {
                        this.message = err.message;
                        this.isError = true;
                    } finally {
                        this.isLoading = false;
                    }
                },

                async loginWithGoogle() {
                    this.isLoading = true;
                    this.message = '';
                    
                    try {
                        const { error } = await window.supabase.auth.signInWithOAuth({
                            provider: 'google',
                            options: {
                                redirectTo: window.location.origin
                            }
                        });
                        if (error) throw error;
                    } catch (err) {
                        this.message = err.message;
                        this.isError = true;
                        this.isLoading = false;
                    }
                }
             }"
        >
            
            <!-- Header -->
            <div class="text-center mb-10">
                <h1 class="text-3xl font-serif font-medium text-gray-900 tracking-tight" x-text="isLogin ? 'Welcome Back' : 'Create Account'"></h1>
                <p class="text-xs text-gray-500 uppercase tracking-widest mt-3 font-bold" x-text="isLogin ? 'Access your signature scents' : 'Join the House of Aju'"></p>
            </div>

            <!-- Dynamic Message Box (Errors or Success) -->
            <div x-show="message" 
                 x-transition
                 :class="isError ? 'bg-red-50 text-red-600 border-red-100' : 'bg-green-50 text-green-600 border-green-100'"
                 class="mb-6 p-4 text-xs font-medium border text-center leading-relaxed" 
                 style="display: none;"
                 x-text="message">
            </div>

            <form @submit.prevent="handleAuth" class="space-y-6">
                <!-- Email Input -->
                <div>
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Email Address</label>
                    <input 
                        type="email" 
                        x-model="email" 
                        required 
                        class="w-full p-4 text-sm bg-gray-50/50 border border-gray-200 focus:border-black focus:ring-0 outline-none transition-colors"
                    >
                </div>

                <!-- Password Input -->
                <div>
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Password</label>
                    <input 
                        type="password" 
                        x-model="password" 
                        required 
                        minlength="6"
                        class="w-full p-4 text-sm bg-gray-50/50 border border-gray-200 focus:border-black focus:ring-0 outline-none transition-colors"
                    >
                </div>

                <!-- Action Button -->
                <button 
                    type="submit" 
                    :disabled="isLoading"
                    class="w-full bg-black text-white py-4 uppercase text-[10px] font-bold tracking-[0.2em] hover:bg-gray-800 transition-colors disabled:opacity-50 flex items-center justify-center gap-3 shadow-xl"
                >
                    <span x-show="!isLoading" x-text="isLogin ? 'Sign In' : 'Create Account'"></span>
                    <span x-show="isLoading" style="display: none;" class="flex items-center gap-2">
                        <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        Processing...
                    </span>
                </button>
            </form>

            <!-- Divider -->
            <div class="mt-8 flex items-center justify-center relative">
                <div class="absolute inset-x-0 h-px bg-gray-200"></div>
                <span class="relative bg-white px-4 text-[10px] uppercase tracking-widest font-bold text-gray-400">Or continue with</span>
            </div>

            <!-- Google OAuth Button -->
            <button 
                @click="loginWithGoogle"
                type="button"
                :disabled="isLoading"
                class="mt-8 w-full bg-white border border-gray-200 text-gray-900 py-4 uppercase text-[10px] font-bold tracking-[0.2em] hover:bg-gray-50 transition-colors flex items-center justify-center gap-3 disabled:opacity-50"
            >
                <svg class="w-4 h-4" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/><path d="M1 1h22v22H1z" fill="none"/></svg>
                Google
            </button>

            <!-- Toggle View -->
            <div class="mt-8 text-center">
                <button 
                    type="button"
                    @click="isLogin = !isLogin; message = ''; isError = false;" 
                    class="text-xs text-gray-500 font-medium hover:text-black transition-colors"
                >
                    <span x-text="isLogin ? 'Don\'t have an account? Create one.' : 'Already have an account? Sign In.'"></span>
                </button>
            </div>

        </div>
    </div>
</Layout>